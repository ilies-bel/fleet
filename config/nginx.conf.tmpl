server {
    listen ${PROXY_PORT};
    root /var/www/html;

    access_log /dev/stdout;
    error_log /dev/stderr warn;

    # Backend proxy
    # Browser calls: http://localhost:${PROXY_PORT}/_fleet/preview/{name}/backend/...
    # Gateway strips /_fleet/preview/{name} → /backend/... arrives here
    # nginx strips /backend prefix → backend app sees /...
    location /backend/ {
        proxy_pass http://127.0.0.1:${BACKEND_PORT}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 60s;
        proxy_connect_timeout 10s;
    }

    # Next.js static export — try file, then .html variant, then SPA fallback
    location / {
        try_files $uri $uri.html $uri/index.html /index.html;
    }
}
