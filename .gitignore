.fleet-ports
# Per-feature directories (info.toml, docker-compose.yml, etc.)
.fleet/*/
!.fleet/.gitkeep
!.fleet/fleet.toml.example
!.fleet/shared.env.example
!.fleet/Dockerfile.feature-base
!.fleet/fragments/
!.fleet/fragments/**
!.fleet/test/
!.fleet/test/**
.fleet-runner.pid
.fleet-config
# Fleet user config (per-machine, not tracked)
.fleet/fleet.toml
# Shared env mounts (replaces .fleet-shared)
.fleet/shared.env
# Legacy
.fleet-shared

# Generated at fleet init time from config/nginx.conf.tmpl
config/nginx.conf
.worktrees/
# Claude Code runtime/tooling state (worktrees, scheduled-task locks, etc.) —
# per-machine, never project source.
.claude/
.DS_Store
node_modules/
gateway/node_modules/
dashboard/node_modules/
dashboard/dist/

# Vite-built dashboard output — generated by `cd dashboard && npm run build`
# (outDir: ../gateway/public, emptyOutDir: true). Never commit; build before publish.
gateway/public/assets/
gateway/public/index.html

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Beads task tracking (ephemeral)
.beads/
.mcp.json

# Mars runtime state (queue/state dbs, watcher pid/socket — per-machine)
.mars/

# Impeccable design-tooling artifacts (critiques + generated product doc) —
# local design byproducts, not project source.
**/.impeccable/
PRODUCT.md


test/project
test/reference