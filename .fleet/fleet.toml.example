# fleet.toml — Fleet project configuration
#
# This file is the single source of truth for a Fleet-managed project.
# Copy this file to .fleet/fleet.toml and adjust to your project.
#
# fleet init will generate this file interactively if it is absent.

# ─── Project ──────────────────────────────────────────────────────────────────
[project]
name = "d2r2"
root = "/Users/x/projects/d2r2"   # absolute path to the project root on this host
path = ".worktrees/{name}"  # path template for git worktrees; {name} expands to the feature name

# ─── Ports ────────────────────────────────────────────────────────────────────
[ports]
proxy = 3000    # nginx reverse proxy (public-facing)
admin = 4000    # fleet gateway admin API
db    = 5432    # host-mapped database port (optional; 0 = disabled)

# ─── Stacks ───────────────────────────────────────────────────────────────────
# Optional. Define custom build stacks used by [[services]].
# `type`         — identifier referenced by services[].stack
# `dockerfile`   — path to the Dockerfile template, relative to project.root
# `shared_paths` — (optional) list of TABLES { path = "...", mode = "bind|volume|copy" }
#                  describing host/primary-checkout state to surface into every feature
#                  container. The worktree source tree is already bind-mounted, so this
#                  is only for things NOT in the worktree (gitignored files, node_modules).
#                  Each entry MUST declare a mode (hard cut — bare strings are rejected):
#                    bind   — bind-mount from the PRIMARY checkout (single source of truth).
#                             Relative paths resolve under the service's root dir; absolute
#                             or "~"-prefixed paths are host paths used as-is.
#                    volume — named docker volume (use for node_modules: arch-correct,
#                             shared across features, avoids the macOS bind-mount perf hit).
#                    copy   — copy from the primary checkout into THIS worktree at add-time,
#                             then bind-mount the copy (true per-feature isolation).
#                  An explicit container target may be given as "src:target" in path:
#                    { path = "~/.npmrc:/root/.npmrc", mode = "bind" }
#
# [[stacks]]
# type         = "vite"
# dockerfile   = ".fleet/Dockerfile.feature-base.vite"
# shared_paths = [{ path = "node_modules", mode = "volume" }]

# ─── Services ─────────────────────────────────────────────────────────────────
# One [[services]] entry per deployable unit.
# `name`               — logical identifier used in fleet commands (e.g. fleet add <name>)
# `dir`                — path of the service source tree, relative to project.root
# `stack`              — must match one of the [[stacks]] type values above
# `port`               — container-internal port the service listens on
# `build`              — command that produces the deployable artefact (run inside the container)
# `run`                — command that starts the service (run inside the container)
# `env_files`          — (optional) list of TABLES { path = "...", mode = "bind|copy" } for
#                        non-tracked (gitignored) env files relative to this service's `dir`,
#                        mounted READ-ONLY into THIS service's container only and sourced
#                        automatically before the service process starts. Because env files
#                        are gitignored they live only in the PRIMARY checkout, which is always
#                        the source of truth:
#                          bind — bind-mount the file straight from the primary checkout.
#                          copy — copy it into the worktree at add-time, then mount the copy.
#                        (mode = "volume" is not valid for a single env file.)
#                        fleet init auto-discovers .env files under a service dir and writes them
#                        here as { path = ".env", mode = "bind" }.
#                        For files that must reach ALL containers use [[shared]] instead.
# `path`              — (optional) per-service worktree path template for multi-repo layouts.
#                        Overrides [project].path for THIS service only.
#                        {name} is substituted with the feature name. Relative paths resolve
#                        from project.root. Use when each service directory is its own git repo
#                        (e.g. frontend/ and backend/ are independent repos inside the project root).
#                        When set, the resolved path is used directly as the mount source for this
#                        service — NOT combined with svc dir. fleet init does NOT emit this key
#                        automatically; it is opt-in.
#                        Example: path = "backend/.worktrees/{name}"
#
# JAR NAMING CONVENTION (gradle/spring stacks):
# Each gradle/spring service's built jar is copied to /home/developer/<service-name>.jar.
# Your `run` command must reference that path — i.e. use the service `name` field, not
# a hardcoded "backend". Example: a service named "jira-proxy" uses /home/developer/jira-proxy.jar.

[[services]]
name  = "backend"
dir   = "d2r2-backend"
stack = "spring"
port  = 8081
# host_port = 8081   # optional — expose this port directly on the host (bypasses nginx proxy)
build = "mvn package -DskipTests -q"
# uses /home/developer/<service-name>.jar — fleet copies the built jar there per-service.
run       = "java -jar /home/developer/backend.jar"
env_files = [{ path = ".env", mode = "bind" }]   # auto-discovered by fleet init; mounted only into the backend container
# Uncomment for multi-repo layout where d2r2-backend/ is its own git repository:
# path = "d2r2-backend/.worktrees/{name}"

[[services]]
name  = "frontend"
dir   = "d2r2-frontend"
stack = "next"
port  = 3000
build = "npm run build"
run       = "npm run dev"
env_files = [{ path = ".env.local", mode = "bind" }]   # auto-discovered by fleet init; mounted only into the frontend container
# Optional per-service env vars; written as KEY=VALUE lines in feature.env.
# env = { JIRA_BASE_URL = "http://127.0.0.1:8089" }
# Uncomment for multi-repo layout where d2r2-frontend/ is its own git repository:
# path = "d2r2-frontend/.worktrees/{name}"

# ─── Peers ────────────────────────────────────────────────────────────────────
# Optional stub services co-located in the feature container (127.0.0.1).
# Peers are started by supervisord alongside the main services; they are NOT
# exposed externally — internal traffic only.
#
# `name`     — unique identifier for this peer (used in supervisord program name)
# `type`     — one of: wiremock | static-http | shell
# `port`     — container-internal port the peer listens on
# `mappings` — (wiremock only) path to WireMock mappings dir, relative to project.root
# `files`    — (wiremock only) path to WireMock __files dir, relative to project.root
# `cmd`      — (shell only) command to run as the peer process
#
# [[peers]]
# name     = "wiremock-edf"
# type     = "wiremock"
# port     = 8080
# mappings = "wiremock-edf/mappings"
# files    = "wiremock-edf/__files"
#
# [[peers]]
# name = "mock-api"
# type = "static-http"
# port = 9090
#
# [[peers]]
# name = "custom-stub"
# type = "shell"
# port = 7070
# cmd  = "node /app/custom-stub/server.js"

# ─── Sidecars ─────────────────────────────────────────────────────────────────
# Optional sibling containers (Postgres, MinIO, Redis, ...) that run alongside
# feature containers on the internal `fleet-net` network. Sidecars are NOT
# exposed on host ports — your services reach them via Docker DNS using the
# network alias documented below.
#
# `name`       — required; ^[a-z0-9]([a-z0-9-]*)?$ — used in container + alias names
# `image`      — required; any docker image reference (postgres:16, redis:7, …)
# `port`       — informational only; sidecars are NOT host-exposed
# `scope`      — "project" (default) or "feature"
#                  project : one shared container per project, lazily started by the
#                            first `fleet add` and reused across all features. Survives
#                            `fleet rm <feature>` and `fleet rm --all`. Removed only by
#                            `fleet rm --nuke` (which also removes its named volumes).
#                  feature : a fresh container per feature, named after the feature and
#                            torn down by `fleet rm <feature>`.
# `env`        — table of KEY = "value" pairs passed via -e
# `volumes`    — list of TABLES { path, target, mode } using the same shape as
#                shared_paths. mode = "volume" creates a named docker volume;
#                mode = "bind" mounts a path from the project root (or an absolute
#                host path). mode = "copy" is NOT supported for sidecars.
# `cmd`        — optional array of strings overriding the image's CMD
# `depends_on` — optional list of other sidecar names; sidecars are started in
#                topological order. Cycles and unknown references are rejected.
#
# DNS / aliases on fleet-net:
#   scope = "project" → alias  fleet-<name>           (e.g. fleet-rag-postgres)
#   scope = "feature" → alias  fleet-<feature>-<name> (e.g. fleet-login-fix-redis)
#   Container name carries the project (and feature, when scoped) for uniqueness:
#     fleet-sidecar-<project>-<name>
#     fleet-sidecar-<project>-<feature>-<name>
#
# Caveats (v1):
#   - Image-tag drift is NOT detected. If you change `image = "postgres:16"` to
#     "postgres:17", lazy-start still finds the running container and does
#     nothing. Run `fleet rm --nuke` to pick up the new image, or manage
#     project-scope sidecars manually via `docker rm`.
#   - For per-feature provisioning (run migrations, seed data, …) use the
#     [hooks].post_add lifecycle hook — it runs after the container is healthy
#     and can shell into the sidecar via its DNS alias.
#
# [[sidecars]]
# name    = "rag-postgres"
# image   = "postgres:16"
# port    = 5432              # informational only — not exposed to host
# scope   = "project"         # shared across all features of this project
# env     = { POSTGRES_PASSWORD = "dev", POSTGRES_USER = "rag", POSTGRES_DB = "rag" }
# volumes = [{ path = "pgdata", target = "/var/lib/postgresql/data", mode = "volume" }]
# cmd     = ["postgres", "-c", "max_connections=200"]
#
# # Your service code reaches this sidecar at: postgres://fleet-rag-postgres:5432/rag
#
# [[sidecars]]
# name       = "scratch-redis"
# image      = "redis:7"
# scope      = "feature"      # a fresh redis per feature, torn down on `fleet rm`
# depends_on = ["rag-postgres"]
#
# # Reached at: fleet-<feature-name>-scratch-redis:6379

# ─── Shared files ─────────────────────────────────────────────────────────────
# Optional. Non-tracked env files to bind-mount READ-ONLY into EVERY feature
# container and source automatically before any service process starts.
# `path`   — path to the file, relative to project.root (required)
# `target` — mount point inside the container (optional; default: /app/<path>)
#
# The file is sourced with `set -a; . "$target"; set +a` so every variable it
# exports becomes visible to the service process without extra wiring.
#
# USE [[shared]] FOR: project-root-level files that must reach every container
#   (e.g. a top-level .env holding shared secrets used by all services).
#
# DO NOT USE [[shared]] FOR: per-service .env files — use services[].env_files
#   instead so the file is mounted only into the relevant service container.
#   fleet init auto-discovers .env files inside a service dir and writes them
#   to services[].env_files automatically, NOT here.
#
# Example — a root-level .env visible to all containers:
# [[shared]]
# path = ".env"
#
# Example — with an explicit container mount point:
# [[shared]]
# path   = ".env.local"
# target = "/app/.env.local"

# ─── Lifecycle hooks ──────────────────────────────────────────────────────────
# Optional. Inline POSIX shell commands run at key points during fleet add / rm.
# Fleet executes each value with `sh -c "<string>"` (POSIX sh, not bash).
# Working directory for every hook: project.root (the directory containing fleet.toml).
#
# Variable interpolation — substitute these placeholders before the string is
# handed to sh (use {var} syntax in the value OR the FLEET_* env var equivalents):
#
#   {name}           / FLEET_FEATURE_NAME   — feature name (e.g. bd-foo)
#   {project}        / FLEET_PROJECT_NAME   — project.name from [project]
#   {worktree_path}  / FLEET_WORKTREE_PATH  — absolute worktree path (or project root in --direct)
#   {branch}         / FLEET_BRANCH         — git branch the worktree is on
#   {direct}         / FLEET_DIRECT         — "true" or "false"
#
# Failure semantics:
#   pre_add / pre_rm  — non-zero exit aborts the operation; fleet exits non-zero.
#   post_add / post_rm — non-zero exit is a warning only; fleet continues.
#
# For complex hooks, call an external script:
#   pre_add = "bash scripts/seed-worktree.sh"
#
# [hooks]
# # Seed node_modules from the primary checkout to avoid a full npm install per worktree.
# pre_add  = "cp -R frontend/node_modules frontend/.worktrees/{name}/node_modules"
# # Notify a Slack webhook after the container comes up.
# post_add = "curl -s -X POST https://hooks.slack.com/... -d 'feature {name} started'"
# # Log which feature is being torn down.
# pre_rm   = "echo 'tearing down {name} (branch: {branch})' >&2"
# # Post-removal notification; non-zero exit is a warning, not a hard failure.
# post_rm  = "curl -s -X POST https://hooks.slack.com/... -d 'feature {name} removed'"
