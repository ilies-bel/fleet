{
  "name": "@ilies-bel/fleet",
  "version": "2.0.0",
  "description": "Local QA environment manager — spin up isolated Docker containers per feature branch",
  "license": "MIT",
  "keywords": [
    "docker",
    "qa",
    "feature-branch",
    "preview",
    "cli",
    "dev-environment"
  ],
  "homepage": "https://github.com/ilies-bel/fleet#readme",
  "bugs": {
    "url": "https://github.com/ilies-bel/fleet/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilies-bel/fleet.git"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "bin": {
    "fleet": "bin/fleet.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "fleet",
    "bin/",
    "cli/",
    "config/",
    "gateway/src/",
    "gateway/public/",
    "gateway/package.json",
    "gateway/Dockerfile",
    "dashboard/src/",
    "dashboard/index.html",
    "dashboard/vite.config.js",
    "dashboard/package.json",
    ".fleet/fleet.toml.example",
    "README.md",
    "!**/*.test.js",
    "!**/*.test.jsx",
    "!**/__tests__/**",
    "!**/test-setup.js"
  ]
}
